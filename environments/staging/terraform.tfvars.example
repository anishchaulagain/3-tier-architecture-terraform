aws_region   = "us-east-1"
environment  = "staging"
project_name = "three-tier"
owner        = "platform-team"

# Network — staging mirrors prod's posture with per-AZ NAT gateways.
vpc_cidr                 = "10.1.0.0/16"
azs                      = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs      = ["10.1.0.0/20", "10.1.16.0/20"]
private_app_subnet_cidrs = ["10.1.64.0/20", "10.1.80.0/20"]
private_db_subnet_cidrs  = ["10.1.128.0/20", "10.1.144.0/20"]
single_nat_gateway       = false
