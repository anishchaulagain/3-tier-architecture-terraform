aws_region   = "us-east-1"
environment  = "dev"
project_name = "three-tier"
owner        = "platform-team"

# Network — dev uses a 2-AZ layout with a single NAT to keep cost low.
vpc_cidr                 = "10.0.0.0/16"
azs                      = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs      = ["10.0.0.0/20", "10.0.16.0/20"]
private_app_subnet_cidrs = ["10.0.64.0/20", "10.0.80.0/20"]
private_db_subnet_cidrs  = ["10.0.128.0/20", "10.0.144.0/20"]
single_nat_gateway       = true
