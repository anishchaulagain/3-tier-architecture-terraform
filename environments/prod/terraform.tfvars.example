aws_region   = "us-east-1"
environment  = "prod"
project_name = "three-tier"
owner        = "platform-team"

# Network — prod runs 3 AZs with a NAT per AZ so a zone outage doesn't kill egress.
vpc_cidr                 = "10.2.0.0/16"
azs                      = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs      = ["10.2.0.0/20", "10.2.16.0/20", "10.2.32.0/20"]
private_app_subnet_cidrs = ["10.2.64.0/20", "10.2.80.0/20", "10.2.96.0/20"]
private_db_subnet_cidrs  = ["10.2.128.0/20", "10.2.144.0/20", "10.2.160.0/20"]
single_nat_gateway       = false
