# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable values — never commit real values.
# Keep *.tfvars.example templates checked in.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Saved plan files
*.tfplan
*.tfplan.*

# IDE / editors
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
